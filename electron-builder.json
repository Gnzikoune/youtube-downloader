{
  "productName": "YT Playlist Downloader",
  "appId": "com.yt.downloader",
  "directories": {
    "output": "dist/build"
  },
  "files": [
    "dist/renderer/**/*",
    "src/main/**/*",
    "resources/**/*",
    "package.json"
  ],
  "win": {
    "target": ["nsis"]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "extraResources": [
    {
      "from": "resources/",
      "to": "resources/",
      "filter": ["**/*"]
    }
  ]
}
