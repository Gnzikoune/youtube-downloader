{
  "name": "youtube-downloader",
  "version": "1.6.0",
  "description": "Un téléchargeur professionnel de playlists YouTube pour Windows, Mac et Linux.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gnzikoune/youtube-downloader.git"
  },
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite --port 3001",
    "dev:electron": "wait-on http://localhost:3001 && nodemon --watch src/main --exec \"cross-env NODE_ENV=development electron .\"",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.16.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.3.9",
    "execa": "^9.6.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.14",
    "semantic-release": "^24.2.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^12.0.1",
    "vite": "^8.0.13",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.youtube.downloader.pro",
    "productName": "YT Downloader Pro",
    "directories": {
      "output": "dist"
    },
    "publish": "github",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "resources/icon.icns",
      "category": "public.app-category.video"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Video"
    }
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]"
        }
      ],
      "@semantic-release/github"
    ]
  }
}
